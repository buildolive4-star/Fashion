        // Leaflet Coordinate Picker Map Initialization
        let map = null;
        let pickerMarker = null;
        function initCoordinatesPickerMap() {
            if (map) return;
            map = L.map('coordinatesPickerMap', {
                center: [28.4595, 77.0266],
                zoom: 12,
                zoomControl: true,
                attributionControl: false
            });

            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                maxZoom: 19
            }).addTo(map);

            map.on('click', function(e) {
                const lat = e.latlng.lat.toFixed(6);
                const lng = e.latlng.lng.toFixed(6);

                document.getElementById('therapistLat').value = lat;
                document.getElementById('therapistLng').value = lng;

                if (pickerMarker) {
                    pickerMarker.setLatLng(e.latlng);
                } else {
                    pickerMarker = L.marker(e.latlng).addTo(map);
                }
            });
        }

        // API Asset upload method bridge to post imagery payload to ImgBB
        async function uploadImageToImgBB(file) {
            const formData = new FormData();
            formData.append("image", file);

            const urlEndpoint = `https://api.imgbb.com/1/upload?key=${IMGBB_API_KEY}`;
            const response = await fetch(urlEndpoint, {
                method: "POST",
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                return result.data.url;
            } else {
                throw new Error(result.error ? result.error.message : "Asset upload transaction failed.");
            }
        }

