<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OOOO Spa - Executive Control Panel</title>
    <!-- Premium Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=Montserrat:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Iconographies -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Leaflet Map CSS for Coordinates Picker -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <style>
        :root {
            --bg-obsidian: #050505;
            --bg-velvet: #0f0f0f;
            --bg-elevated: #161616;
            --rose-pink: #E8A7B7;
            --rose-glow: rgba(232, 167, 183, 0.1);
            --gold-metallic: #D4AF37;
            --gold-gradient: linear-gradient(135deg, #E6C875 0%, #D4AF37 50%, #AA7C11 100%);
            --white: #FDFBFB;
            --text-muted: #A39F9E;
            --border-glow: rgba(212, 175, 55, 0.2);
            --border-light: rgba(255, 255, 255, 0.05);
            --transition-premium: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Basic Layout System Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            outline: none;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-obsidian);
            color: var(--white);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        h1, h2, h3, h4, .brand-logo {
            font-family: 'Cinzel', serif;
            font-weight: 600;
            letter-spacing: 1.5px;
        }

        /* login overlay gate */
        #loginGateOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(5,5,5,0.98);
            backdrop-filter: blur(15px);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            transition: var(--transition-premium);
        }

        .login-card {
            background-color: var(--bg-velvet);
            border: 1px solid var(--border-glow);
            border-radius: 28px;
            padding: 45px 35px;
            max-width: 420px;
            width: 100%;
            text-align: center;
            box-shadow: 0 30px 70px rgba(0,0,0,0.9), inset 0 0 30px rgba(212,175,55,0.05);
        }

        .login-card h2 {
            font-size: 1.8rem;
            color: var(--gold-metallic);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        .login-card p {
            font-size: 0.82rem;
            color: var(--text-muted);
            margin-bottom: 35px;
            font-weight: 300;
            line-height: 1.5;
        }

        /* Input Controls Admin styling */
        .glass-input-wrapper {
            display: flex;
            flex-direction: column;
            text-align: left;
            margin-bottom: 24px;
        }

        .glass-input-wrapper label {
            font-size: 0.7rem;
            color: var(--gold-metallic);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .glass-input {
            background-color: rgba(15,15,15,0.8);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            color: var(--white);
            padding: 15px 20px;
            font-size: 0.9rem;
            font-family: inherit;
            transition: var(--transition-premium);
        }

        .glass-input:focus {
            border-color: var(--gold-metallic);
            background-color: rgba(20,20,20,0.95);
            box-shadow: 0 0 15px rgba(212,175,55,0.15);
        }

        select.glass-input {
            appearance: none;
            background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23D4AF37%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E');
            background-repeat: no-repeat;
            background-position: right 15px top 50%;
            background-size: 10px auto;
        }

        /* Admin Action Buttons */
        .btn-luxury-admin {
            background: var(--gold-gradient);
            color: var(--bg-obsidian);
            border: none;
            padding: 16px 30px;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-radius: 12px;
            cursor: pointer;
            transition: var(--transition-premium);
            width: 100%;
            display: inline-block;
            box-shadow: 0 10px 25px rgba(212,175,55,0.25);
        }

        .btn-luxury-admin:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(212,175,55,0.4);
        }

        .btn-luxury-admin:active {
            transform: translateY(0);
        }

        /* Dashboard Top Header Navigation Bar */
        .admin-nav-header {
            height: 95px;
            background-color: var(--bg-velvet);
            border-bottom: 1px solid var(--border-light);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 45px;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        }

        .admin-logo {
            font-family: 'Cinzel', serif;
            font-size: 1.9rem;
            font-weight: 800;
            color: transparent;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            letter-spacing: 3.5px;
            cursor: pointer;
        }

        .admin-logo span {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.65rem;
            color: var(--white);
            display: block;
            letter-spacing: 2px;
            opacity: 0.8;
            margin-top: 4px;
            text-shadow: none;
        }

        .header-controls {
            display: flex;
            align-items: center;
            gap: 30px;
        }

        .system-status-badge {
            background-color: rgba(37, 211, 102, 0.08);
            border: 1px solid rgba(37, 211, 102, 0.25);
            color: #25d366;
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 0.75rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: 0.5px;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            background-color: #25d366;
            border-radius: 50%;
            animation: pulse-green 1.5s infinite;
        }

        @keyframes pulse-green {
            0% { opacity: 0.3; transform: scale(0.8); }
            50% { opacity: 1; transform: scale(1.2); }
            100% { opacity: 0.3; transform: scale(0.8); }
        }

        .btn-admin-logout {
            background-color: rgba(217, 83, 79, 0.08);
            border: 1px solid rgba(217, 83, 79, 0.3);
            color: #d9534f;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-premium);
            letter-spacing: 1px;
        }

        .btn-admin-logout:hover {
            background-color: #d9534f;
            color: white;
            border-color: transparent;
            box-shadow: 0 5px 15px rgba(217, 83, 79, 0.4);
        }

        /* Workspace Grid and Sidebar Tabs systems */
        .dashboard-container {
            display: flex;
            flex: 1;
        }

        .dashboard-sidebar {
            width: 280px;
            background-color: var(--bg-velvet);
            border-right: 1px solid var(--border-light);
            padding: 35px 25px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .sidebar-tab-btn {
            background: transparent;
            border: 1px solid transparent;
            color: var(--text-muted);
            padding: 16px 20px;
            border-radius: 12px;
            text-align: left;
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.5px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: var(--transition-premium);
        }

        .sidebar-tab-btn i {
            font-size: 1.25rem;
            width: 24px;
            text-align: center;
        }

        .sidebar-tab-btn:hover, .sidebar-tab-btn.active {
            color: var(--gold-metallic);
            background-color: rgba(212, 175, 55, 0.05);
            border-color: rgba(212, 175, 55, 0.15);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        /* Workspace Panel Wrapper */
        .dashboard-content-panel {
            flex: 1;
            padding: 45px 55px;
            overflow-y: auto;
            max-height: calc(100vh - 95px);
            background: linear-gradient(135deg, var(--bg-obsidian) 0%, #0a0a0a 100%);
        }
        .dashboard-content-panel::-webkit-scrollbar { display: none; }

        .dashboard-pane {
            display: none;
            animation: paneFadeIn 0.5s ease-out forwards;
        }

        .dashboard-pane.active {
            display: block;
        }

        @keyframes paneFadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .pane-header-title {
            font-size: 1.8rem;
            color: var(--white);
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .pane-header-desc {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 45px;
            font-weight: 300;
            line-height: 1.6;
        }

        /* Overview Summary KPI Cards Grid */
        .kpi-row-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
            margin-bottom: 45px;
        }

        .kpi-metric-card {
            background: linear-gradient(145deg, #121212 0%, #080808 100%);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 30px 25px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: var(--transition-premium);
        }
        .kpi-metric-card:hover {
            border-color: var(--gold-metallic);
            transform: translateY(-5px);
        }

        .kpi-left h5 {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .kpi-left .kpi-value {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--gold-metallic);
            text-shadow: 0 2px 10px rgba(212,175,55,0.2);
        }

        .kpi-metric-card i {
            font-size: 2.5rem;
            color: var(--rose-pink);
            opacity: 0.7;
        }

        /* Two Column Layout blocks */
        .workspace-split-columns {
            display: grid;
            grid-template-columns: 1.2fr 1.8fr;
            gap: 45px;
            align-items: flex-start;
        }

        @media (max-width: 1199px) {
            .workspace-split-columns {
                grid-template-columns: 1fr;
            }
            .dashboard-container {
                flex-direction: column;
            }
            .dashboard-sidebar {
                width: 100%;
                flex-direction: row;
                overflow-x: auto;
                padding: 15px 25px;
            }
            .sidebar-tab-btn {
                white-space: nowrap;
            }
            .dashboard-content-panel {
                padding: 30px;
            }
        }

        .admin-glass-card {
            background-color: var(--bg-velvet);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 24px;
            padding: 35px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        }

        .card-inner-subtitle {
            font-size: 1.2rem;
            margin-bottom: 25px;
            color: var(--gold-metallic);
            text-transform: uppercase;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 15px;
            letter-spacing: 1px;
        }

        /* drag-drop file uploader styling */
        .drag-uploader-area {
            border: 2px dashed rgba(212, 175, 55, 0.3);
            background-color: rgba(5,5,5,0.5);
            border-radius: 16px;
            padding: 35px 20px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition-premium);
            margin-bottom: 25px;
            position: relative;
        }

        .drag-uploader-area:hover {
            border-color: var(--gold-metallic);
            background-color: rgba(212, 175, 55, 0.05);
        }

        .drag-uploader-area input[type="file"] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

        .drag-uploader-area i {
            color: var(--gold-metallic);
            font-size: 2.2rem;
            margin-bottom: 15px;
        }

        .drag-uploader-area p {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 400;
        }

        /* Active Lists Display Grid */
        .banners-thumbnail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 25px;
        }

        .banner-manage-item {
            background-color: var(--bg-obsidian);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 5px 15px rgba(0,0,0,0.4);
        }

        .banner-thumbnail-wrap {
            width: 100%;
            aspect-ratio: 16/9;
            background-size: cover;
            background-position: center;
        }

        .banner-manage-footer {
            padding: 12px;
            display: flex;
            justify-content: flex-end;
            background-color: rgba(0,0,0,0.5);
        }

        .btn-delete-asset {
            background: rgba(217, 83, 79, 0.1);
            border: 1px solid rgba(217, 83, 79, 0.4);
            color: #d9534f;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-premium);
        }

        .btn-delete-asset:hover {
            background: #d9534f;
            color: white;
            border-color: transparent;
            box-shadow: 0 4px 10px rgba(217, 83, 79, 0.3);
        }

        /* 3-Column 9:16 Therapist Portrait Grid Configuration */
        .therapist-portrait-3column-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 30px;
        }

        .therapist-list-portrait-card {
            background-color: rgba(10,10,10,0.8);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            overflow: hidden;
            transition: var(--transition-premium);
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

        .therapist-list-portrait-card:hover {
            border-color: var(--gold-metallic);
            box-shadow: 0 10px 30px rgba(212,175,55,0.15);
        }

        .therapist-9to16-img {
            width: 100%;
            aspect-ratio: 9 / 12; /* Square to Portrait logic */
            background-size: cover;
            background-position: center;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            padding: 20px;
            position: relative;
        }

        .therapist-9to16-img::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.9) 100%);
        }

        .therapist-9to16-tag {
            background-color: rgba(5, 5, 5, 0.9);
            border: 1px solid var(--gold-metallic);
            color: var(--gold-metallic);
            padding: 6px 14px;
            border-radius: 25px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            z-index: 2;
        }

        .therapist-pending-badge {
            background-color: #F59E0B; /* Orange */
            color: #000;
            padding: 6px 14px;
            border-radius: 25px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            position: relative;
            z-index: 2;
        }

        .therapist-portrait-body {
            padding: 25px;
        }

        .therapist-portrait-body h3 {
            font-family: 'Cinzel', serif;
            font-size: 1.25rem;
            margin-bottom: 8px;
            color: var(--white);
        }

        .therapist-portrait-spec {
            font-size: 0.85rem;
            color: var(--rose-pink);
            font-weight: 500;
            margin-bottom: 12px;
        }

        .therapist-portrait-desc {
            font-size: 0.8rem;
            color: var(--text-muted);
            line-height: 1.6;
            font-weight: 300;
            margin-bottom: 20px;
        }

        /* Generic Admin List Items styling */
        .generic-admin-list {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .generic-admin-item {
            background-color: rgba(10,10,10,0.8);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 20px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            transition: var(--transition-premium);
        }
        .generic-admin-item:hover {
            border-color: rgba(212, 175, 55, 0.3);
        }

        /* Booking Approval list custom styling */
        .booking-approval-list {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .booking-approval-card {
            background-color: rgba(15,15,15,0.7);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

        .booking-approval-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 18px;
            margin-bottom: 20px;
        }

        .booking-status-badge {
            padding: 6px 16px;
            border-radius: 25px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .status-pending {
            background-color: rgba(212, 175, 55, 0.1);
            border: 1px solid rgba(212, 175, 55, 0.4);
            color: var(--gold-metallic);
        }

        .status-approved {
            background-color: rgba(59, 130, 246, 0.1); /* Blue for approved/active */
            border: 1px solid rgba(59, 130, 246, 0.4);
            color: #3B82F6;
        }

        .status-completed {
            background-color: rgba(16, 185, 129, 0.1); /* Green for completed */
            border: 1px solid rgba(16, 185, 129, 0.4);
            color: #10B981;
        }

        .booking-details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .booking-detail-item {
            display: flex;
            flex-direction: column;
            gap: 6px;
            background: rgba(0,0,0,0.3);
            padding: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.03);
        }

        .booking-detail-item span {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .booking-detail-item strong {
            font-size: 0.95rem;
            color: var(--white);
            font-weight: 500;
        }

        /* Client Database List Styles */
        .client-database-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .client-card {
            background: linear-gradient(145deg, #121212 0%, #0a0a0a 100%);
            border: 1px solid rgba(212, 175, 55, 0.15);
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.5);
            position: relative;
            transition: var(--transition-premium);
        }
        .client-card:hover {
            border-color: var(--gold-metallic);
            transform: translateY(-3px);
        }

        .client-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--border-light);
            padding-bottom: 15px;
        }

        .client-header h4 {
            font-size: 1.1rem;
            color: var(--white);
            margin-bottom: 5px;
            font-weight: 600;
        }

        .client-phone {
            font-size: 0.85rem;
            color: var(--gold-metallic);
            font-weight: 500;
        }

        .client-info-row {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 8px;
        }
        .client-info-row i { color: var(--rose-pink); width: 16px; text-align: center; }

        /* Custom System Toast Alert */
        .admin-toast-box {
            position: fixed;
            bottom: 40px;
            right: 40px;
            background-color: var(--bg-velvet);
            border: 1px solid var(--gold-metallic);
            color: var(--white);
            border-radius: 12px;
            padding: 20px 30px;
            font-size: 0.9rem;
            font-weight: 600;
            display: none;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
            z-index: 100000;
            animation: toastSlide 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes toastSlide {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        /* Live Loader Ring styling */
        .luxury-loader-wrap {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
